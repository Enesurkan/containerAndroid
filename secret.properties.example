# Copy to secret.properties and set values. Do not commit secret.properties or keystore.

# Optional: default API key for "Geç" (skip) flow in activation.
DEFAULT_API_KEY=

# Optional: certificate pinning for api.dienu.work (see docs/CERT_PINNING.md).
# CERT_PIN_API_DIENU_WORK=sha256/...

# Release signing (required for store upload). Create keystore first (see docs/STORE_RELEASE.md).
# STORE_FILE=keystore/altintakip-upload.jks
# STORE_PASSWORD=your_keystore_password
# KEY_ALIAS=altintakip
# KEY_PASSWORD=your_key_password
